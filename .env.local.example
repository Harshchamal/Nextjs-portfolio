# Copy this file to .env.local for local development, and add the same
# keys/values in Vercel Project Settings -> Environment Variables for production.
# Never commit the real .env.local file.

# Password to log into /dashboard. Choose your own value here and in Vercel.
DASHBOARD_PASSWORD=Harsha2004

# Random long string used to sign the dashboard login session cookie.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SESSION_SECRET=change-this-to-a-long-random-string

# GitHub Personal Access Token (fine-grained, scoped to this repo only,
# with "Contents: Read and write" permission). The dashboard uses this to
# commit project/image changes directly to your repo.
GITHUB_TOKEN=

# Repo the dashboard commits to.
GITHUB_OWNER=Harshchamal
GITHUB_REPO=Nextjs-portfolio
GITHUB_BRANCH=master
